# Meryl Shoes Enterprise System - Environment Configuration
# Copy this file to .env and fill in your actual values

# SUPABASE CONFIGURATION
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_publishable_key

# GMAIL SMTP CONFIGURATION FOR OTP EMAILS
# Gmail SMTP Settings (Required for OTP email functionality)
GMAIL_APP_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-specific-password

# Optional SMTP Configuration (defaults provided)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ============================================
# SETUP INSTRUCTIONS FOR GMAIL SMTP
# ============================================
#
# 1. Enable 2-Factor Authentication on your Gmail account
#    - Go to myaccount.google.com
#    - Click "Security" on the left menu
#    - Enable "2-Step Verification"
#
# 2. Create an App-Specific Password
#    - Go to myaccount.google.com/apppasswords
#    - Select "Mail" and "Windows Computer" (or your device)
#    - Google will generate a 16-character password
#    - Copy and paste this password as GMAIL_APP_PASSWORD
#
# 3. Set GMAIL_APP_EMAIL to your Gmail address
#    - Example: myname@gmail.com
#
# 4. Save this file and restart the application
#
# Once configured, users can create accounts and receive OTP codes via email.
# ============================================
